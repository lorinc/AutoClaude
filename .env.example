# Anthropic API key — from console.anthropic.com under API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID — your personal chat ID with the bot (see setup instructions)
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Orchestrator environment
ORCHESTRATOR_ENV=dev

# Set to true to print Claude invocations without executing them
DRY_RUN=false
